    "body": [
      "\"product-quantity\": {",
      "  \"props\": {",
      "    \"selectorType\": \"${1|stepper,select|}\",",
      "    \"showLabel\": ${2|true,false|},",
      "    \"showUnit\": ${3|true,false|}",
      "  }",
      "}"
    ],
    "description": "Seletor de quantidade (product-quantity)"
